# ============================
# Node.js Backend Environment
# ============================
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/creditsaathi?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-256-bit-jwt-secret-here
JWT_REFRESH_SECRET=your-256-bit-refresh-secret-here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Firebase Storage
FIREBASE_PROJECT_ID=creditsaathi
FIREBASE_STORAGE_BUCKET=creditsaathi.appspot.com
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-key.json

# Email (Gmail SMTP — free, up to 500 emails/day)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# CORS
ALLOWED_ORIGIN=http://localhost:3000

# ============================
# Python ML Service Environment
# ============================
# (Copy these to ml/.env)
# MODEL_PATH=./models/xgboost_v1.joblib
# SCALER_PATH=./models/scaler.joblib
# ML_PORT=8000
# LOG_LEVEL=info
